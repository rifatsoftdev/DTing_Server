# Server Version and Debug mode
VERSION=1.0.8
DEBUG=True
APP_BASE_URL=http://192.168.1.100:8000
LOG_LEVEL=info
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
PRIVATE_KEY_PATH=etc/secrets/private.pem
PUBLIC_KEY_PATH=etc/secrets/public.pem

# Service Charge configuration
SERVICE_CHARGE=1.0

# DataBase configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dting_db

# Email configuration
EMAIL_ADDRESS=email@gmail.com
EMAIL_PASSWORD=app_password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False

# Twilio configuration
TWILIO_ACCOUNT_SID=your_sid
TWILIO_AUTH_TOKEN=your_token
TWILIO_PHONE_NUMBER=+15005550006

# Cloudinary configuration
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_CLOUD_NAME=your-cloud-name

# JWT configuration
SECRET_KEY=your-secret-key
ALGORITHM=HS256
ACCESS_EXPIRE=12
REFRESH_EXPIRE=30
OTP_TOKEN_EXPIRE_MIN=5
PASS_RST_TOKEN_EXPIRE_MIN=15

# Redis configuration
REDIS_URL=redis://localhost:6379
EMAIL_QUEUE_NAME=email_queue
EMAIL_FAILED_QUEUE_NAME=email_failed_queue
SMS_QUEUE_NAME=sms_queue
SMS_FAILED_QUEUE_NAME=sms_failed_queue
EMAIL_MAX_ATTEMPTS=5
EMAIL_WORKER_POLL_TIMEOUT=5
SMS_MAX_ATTEMPTS=5
SMS_WORKER_POLL_TIMEOUT=5

# Salt for password hashing
SALT=your-random-salt-string

# Firebase configuration
FIREBASE_SERVICE_ACCOUNT=your-firebase-adminsdk.json
GOOGLE_CLIENT_ID=google-client-id
GOOGLE_CLIENT_SECRET=google-client-secret

# Default admin
DEFAULT_ADMIN_EMAIL=admin@dting.com
DEFAULT_ADMIN_NAME=Admin DTing
DEFAULT_ADMIN_PASSWORD=Admin@123
DEFAULT_ADMIN_PHONE=01700000000

# Default user
DEFAULT_USER_EMAIL=admin@dting.com
DEFAULT_USER_NAME=DTing User
DEFAULT_USER_PASSWORD=User@123
DEFAULT_USER_PHONE=01700000000

# Other Server URL
VIRELIX_SERVER_URL=http://192.168.1.100:8100/
DTUBE_SERVER_URL=http://192.168.1.100:8200/